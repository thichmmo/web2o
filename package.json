{
  "name": "thichcuu-facebook-tool",
  "version": "1.0.0",
  "description": "Facebook Video 2-Card Carousel Tool - Full Stack Web Application",
  "private": true,
  "workspaces": [
    "server",
    "frontend",
    "admin"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspaces",
    "build:server": "npm run build --workspace=server",
    "build:frontend": "npm run build --workspace=frontend",
    "build:admin": "npm run build --workspace=admin",
    "start": "npm run start --workspace=server",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "migrate": "npm run migrate --workspace=server",
    "seed": "npm run seed --workspace=server"
  },
  "keywords": [
    "facebook",
    "carousel",
    "video",
    "marketing"
  ],
  "author": "Thich Cuu",
  "license": "UNLICENSED",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
