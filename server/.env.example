# Server Configuration
NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=thichcuu_fb_tool
DB_USER=root
DB_PASSWORD=your_password_here
API_VERSION=v1

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_EXPIRES_IN=7d

# Facebook App Credentials
# Live page carousel publish needs a Facebook token/app with:
# pages_show_list,pages_read_engagement,pages_manage_posts,publish_video,ads_read,ads_management
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_GRAPH_VERSION=v21.0
FACEBOOK_DEV_MOCK_ENABLED=true
# Backward-compatible aliases
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret

# File Upload
MAX_UPLOAD_SIZE_MB=500
MAX_FILE_SIZE=100MB
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
